# ── Required ────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

REDIS_URL=redis://localhost:6379/0

# Google OAuth2 App credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Stitch Auth ──────────────────────────────────────────────────────────────
# Static bearer token (service account / API key) used as fallback
# Get from: https://stitch.withgoogle.com/docs/mcp/setup
GOOGLE_STITCH_STATIC_TOKEN=ya29.xxx...

# ── Security ─────────────────────────────────────────────────────────────────
# Shared secret between n8n and backend (set as HTTP header X-N8N-Secret)
N8N_WEBHOOK_SECRET=generate-a-random-32-char-string-here
